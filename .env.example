# Server-only settings for Netlify Functions. Never place real keys in public/.
GEMINI_API_KEY=replace_with_your_google_gemini_api_key
DEEPSEEK_API_KEY=replace_with_your_deepseek_api_key
FIREBASE_API_KEY=replace_with_your_firebase_web_api_key
FIREBASE_PROJECT_ID=replace_with_your_firebase_project_id
# Store the complete Firebase service-account JSON in the host secret manager.
# Never commit it or expose it to public browser code.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional provider selection
DEEPSEEK_MODEL=deepseek-v4-pro
GEMINI_MODELS=gemini-3.5-flash,gemini-flash-latest,gemini-2.5-flash

# Optional production hardening
ALLOWED_ORIGINS=https://twinkleos.netlify.app
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_WINDOW_MS=60000
PROVIDER_TIMEOUT_MS=45000
PROVIDER_RETRIES=1
PROVIDER_ORDER=deepseek,gemini,openai,ollama

# Optional OpenAI-compatible provider (OpenAI, compatible hosted gateway, etc.)
OPENAI_COMPATIBLE_API_KEY=replace_with_your_openai_compatible_key
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_MODEL=replace_with_your_model_name

# Optional Ollama adapter. Only loopback URLs are accepted; this requires a
# self-hosted Twinkle gateway because hosted Netlify cannot reach user localhost.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=replace_with_your_local_model

# Optional model routing
MODEL_ROLE_ROUTER=
MODEL_ROLE_PLANNER=
MODEL_ROLE_CODER=
MODEL_ROLE_VISION=
MODEL_ROLE_SUMMARIZER=

# Optional semantic embeddings. Without this, retrieval safely uses keywords.
EMBEDDING_API_URL=https://your-embedding-provider.example/v1/embeddings
EMBEDDING_API_KEY=replace_with_your_embedding_key
EMBEDDING_MODEL=replace_with_your_embedding_model

# Optional web search and connector services. All endpoints must use HTTPS.
SEARCH_API_URL=https://your-search-service.example/search
SEARCH_API_KEY=replace_with_your_search_key
GITHUB_TOOL_WEBHOOK_URL=
SANDBOX_RUNNER_URL=
MCP_GATEWAY_URL=
CONNECTOR_SHARED_TOKEN=replace_with_a_random_connector_token
TOOL_PERMISSIONS_JSON={}

# Optional persistent worker dispatcher for scheduled agents.
BACKGROUND_WORKER_URL=
BACKGROUND_WORKER_TOKEN=replace_with_a_random_worker_token

# Optional cost estimates. Set these from your current provider contract.
DEEPSEEK_INPUT_USD_PER_MILLION=
DEEPSEEK_OUTPUT_USD_PER_MILLION=
GEMINI_INPUT_USD_PER_MILLION=
GEMINI_OUTPUT_USD_PER_MILLION=
OPENAI_INPUT_USD_PER_MILLION=
OPENAI_OUTPUT_USD_PER_MILLION=
